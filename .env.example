# Copy this file to `.env` and adjust as needed.
# All variables are optional — the app falls back to the defaults shown here.

# PostgreSQL connection string the app uses to connect.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# The default matches the database defined in docker-compose.yml.
DATABASE_URL=postgresql://postgres:password@localhost:5432/war_game

# Number of games to simulate and persist in a single run.
NUMBER_OF_GAMES=10

# Maximum rounds to play before a game is cut off and marked "max".
# Prevents a rare non-terminating game from running forever.
MAX_ROUNDS=1000

# Logging verbosity: error | info | debug (default: info).
# Use "debug" to see per-round play-by-play; "error" for quiet runs.
LOG_LEVEL=info
